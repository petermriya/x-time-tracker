{
  "manifest_version": 3,
  "name": "X Time Tracker",
  "version": "1.1",
  "description": "Track daily time spent on X (Twitter) and block access after 1 hour.",
  "permissions": ["storage", "tabs", "alarms"],
  "host_permissions": ["https://x.com/*", "https://twitter.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  }
}